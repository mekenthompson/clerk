{
  "permissions": {
    {{#if tools.allow}}
    "allow": [{{#each tools.allow}}"{{this}}"{{#unless @last}}, {{/unless}}{{/each}}]
    {{else}}
    "allow": []
    {{/if}}
    {{#if tools.deny}},
    "deny": [{{#each tools.deny}}"{{this}}"{{#unless @last}}, {{/unless}}{{/each}}]
    {{/if}}
  },
  "enabledPlugins": {
    "telegram@claude-plugins-official": true
  }{{#if mcpServers}},
  "mcpServers": {{{json mcpServers}}}
  {{/if}}{{#if skipPermissionPrompt}},
  "skipDangerousModePermissionPrompt": true
  {{/if}}
}
